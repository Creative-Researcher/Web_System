@model Web_System.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Faculty Portal | PIRDS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-image: url('/images/Modern-art-Purple-lights-background-Graphics-103278562-1.jpg');
            background-size: cover;
            background-attachment: fixed;
            min-height: 100vh;
            color: white;
            font-family: 'Segoe UI', sans-serif;
            padding: 40px 0;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
            height: 100%;
        }

        .profile-img {
            width: 100px; height: 100px;
            border-radius: 50%; border: 3px solid #A907FA;
            margin-bottom: 15px; box-shadow: 0 0 15px rgba(169, 7, 250, 0.6);
        }

        .btn-user-action {
            background: linear-gradient(45deg, #A907FA, #6C00FF);
            border: none;
            color: white; border-radius: 12px;
            margin-bottom: 10px; transition: 0.3s;
            width: 100%; text-align: center;
            padding: 15px; text-decoration: none; display: block;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-user-action:hover { 
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(169, 7, 250, 0.4); 
            color: white; 
        }

        .form-control-glass {
            background: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            color: white !important; 
            border-radius: 10px;
        }
        
        .form-control-glass::placeholder { color: rgba(255,255,255,0.4); }

        .status-badge {
            background: rgba(169, 7, 250, 0.2);
            color: #E384FF;
            border: 1px solid rgba(169, 7, 250, 0.3);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.8rem;
        }
        
        .table { color: white !important; }
    </style>
</head>
<body>
<div class="container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4" style="background: rgba(40, 167, 69, 0.2); color: #2ecc71;">
            ✅ @TempData["SuccessMessage"]
        </div>
    }

    @if (Model != null)
    {
        <div class="row mb-4">
            <div class="col-12 d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="fw-bold mb-0">FACULTY PORTAL</h1>
                    <p class="text-info small">Predictive Institutional Resource Planning</p>
                </div>
                <a asp-action="Logout" class="btn btn-outline-danger px-4 rounded-pill">Logout</a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="glass-card text-center">
                    <img src="https://ui-avatars.com/api/?name=@Model.FullName&background=A907FA&color=fff" class="profile-img">
                    <h3>@Model.FullName</h3>
                    <p class="text-info fw-bold">@Model.Position</p>
                    <hr class="opacity-25">
                    <div class="text-start mt-4">
                        <p class="small mb-1 opacity-50 uppercase">Current Assignment</p>
                        <p class="fw-bold">Institutional Planning & Resources</p>
                        
                        <p class="small mb-1 mt-3 opacity-50 uppercase">System Status</p>
                        <p class="text-success"><span class="spinner-grow spinner-grow-sm text-success"></span> AI Engine Active</p>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="glass-card">
                    <h5 class="mb-4">🛠️ IDENTIFY INSTITUTIONAL PROBLEM</h5>
                    <form asp-action="SubmitPlanningData" method="post">
                        <input type="hidden" name="facultyId" value="@Model.Id" />
                        
                        <div class="mb-3">
                            <label class="small mb-2 opacity-75">Planning Period (e.g. 1st Sem 2026):</label>
                            <input type="text" name="planningPeriod" class="form-control-glass form-control" required placeholder="Enter current period..." />
                        </div>

                        <div class="mb-3">
                            <label class="small mb-2 opacity-75">Detailed Description of the Problem/Lack:</label>
                            <textarea name="resourceRequest" class="form-control-glass form-control" rows="6" required 
                                placeholder="Example: The marketing department lacks high-end workstations for video rendering, causing project bottlenecks."></textarea>
                        </div>

                        <button type="submit" class="btn-user-action mt-2">🚀 ANALYZE & SUBMIT TO ADMIN</button>
                    </form>
                    
                    <div class="mt-4 p-3 rounded" style="background: rgba(0, 210, 255, 0.05); border: 1px solid rgba(0, 210, 255, 0.2);">
                        <p class="small mb-0 text-info">💡 <strong>AI Tip:</strong> Use keywords like "broken", "market", "industrial", or "revenue" to help the system categorize your problem correctly for the Strategic Panel.</p>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="glass-card mt-2">
                    <h5 class="mb-4">📋 MY RECENT SUBMISSIONS & SYSTEM PREDICTIONS</h5>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="opacity-50 small">
                                <tr>
                                    <th>Period</th>
                                    <th>Problem Submitted</th>
                                    <th>System Prediction</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.MyRequests != null)
                                {
                                    foreach (var req in ViewBag.MyRequests)
                                    {
                                        <tr>
                                            <td class="text-info">@req.Period</td>
                                            <td class="small" style="max-width: 300px;">@req.Details</td>
                                            <td><span class="status-badge">@req.Status</span></td>
                                            <td><span class="badge bg-success bg-opacity-25 text-success border border-success">Recorded</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-center py-4 text-muted">No submissions yet. Submit a problem above to start.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
</body>
</html>