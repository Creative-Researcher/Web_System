@model List<Web_System.Models.User>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Strategic Panel | PIRDS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { 
            background: radial-gradient(circle at bottom left, #1a0129, #330055, #0d0014); 
            min-height: 100vh; 
            color: white; 
            font-family: 'Segoe UI', sans-serif; 
            padding: 30px; 
            background-attachment: fixed;
        }

        .glass-card { 
            background: rgba(255, 255, 255, 0.05); 
            backdrop-filter: blur(15px); 
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1); 
            border-radius: 20px; 
            padding: 25px; 
            box-shadow: 0 8px 32px rgba(0,0,0,0.5); 
            margin-bottom: 20px;
        }

        .btn-predict { 
            background: linear-gradient(45deg, #A907FA, #FF1493); 
            border: none; color: white; font-weight: bold; 
            border-radius: 12px; transition: 0.3s; 
        }
        .btn-predict:hover { transform: scale(1.02); box-shadow: 0 0 20px rgba(169, 7, 250, 0.4); }

        .table { color: white !important; vertical-align: middle; }
        .text-prediction { color: #00d2ff; font-weight: 600; }
        .ai-insight { font-size: 0.85rem; border-left: 2px solid #a855f7; padding-left: 10px !important; }

        .badge-priority {
            background: rgba(169, 7, 250, 0.3) !important; 
            border: 1px solid #A907FA;
        }

        @@media print {
            .no-print { display: none !important; }
            body { background: white !important; color: black !important; }
            .glass-card { border: 1px solid #eee !important; color: black !important; background: transparent !important; box-shadow: none !important; }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4 no-print">
            <h1>💜 ADMIN STRATEGIC PANEL</h1>
            <div>
                <button onclick="window.print()" class="btn btn-light shadow-sm me-2">📄 Export Report</button>
                <a href="@Url.Action("Logout", "Home")" class="btn btn-outline-danger">Logout</a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-5 no-print">
                <div class="glass-card text-center">
                    <h4 class="text-info">🔮 AI Predictive Distribution</h4>
                    <div style="height: 300px; position: relative;">
                        <canvas id="predictionChart"></canvas>
                    </div>
                    
                    <div class="mt-4">
                        <p class="mb-1 small opacity-50">Dominant Forecast:</p>
                        <h5 class="text-prediction">@ViewBag.MostNeeded</h5>
                    </div>

                    <form asp-action="GenerateForecast" method="post" class="mt-3">
                        <button type="submit" class="btn btn-predict w-100 py-3">🔄 RE-SYNC ANALYTICS</button>
                    </form>
                </div>

                <div class="glass-card">
                    <h3>👥 Faculty & Staff</h3>
                    <table class="table table-sm mt-3">
                        <thead>
                            <tr><th>Name</th><th>Position</th><th>Action</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model) {
                                <tr>
                                    <td>@user.FullName</td>
                                    <td><small>@user.Position</small></td>
                                    <td>
                                        <a href="@Url.Action("UserDashboard", "Home", new { id = user.Id })" class="btn btn-sm btn-outline-info">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-md-7">
                <div class="glass-card">
                    <h3>📥 Institutional Need Analysis</h3>
                    <div class="table-responsive">
                        <table class="table mt-3">
                            <thead>
                                <tr class="border-bottom border-secondary">
                                    <th>Staff Submitter</th>
                                    <th>Problem Identified</th>
                                    <th>AI Prediction & Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                     
                            </tbody>
                        </table>
                    </div>
                    <p class="small opacity-50 mt-3 no-print">Note: Admins are guided by system predictions for long-term budget and resource allocation.</p>
                </div>

                <div class="glass-card">
                    <h3>📜 Historical Utilization</h3>
                    <table class="table table-sm">
                        <thead>
                            <tr><th>Date</th><th>Description</th><th>Qty</th></tr>
                        </thead>
                       <tbody>
    @if (ViewBag.PredictiveReports != null)
    {
        @foreach (var report in ViewBag.PredictiveReports)
        {
            <tr>
                <td>@report.StaffName</td>
                <td>@report.ProblemDetails</td>
                <td>@report.AISuggestion</td>
            </tr>
        }
    }
    else
    {
        <tr>
            <td colspan="3" class="text-center opacity-50">No predictive reports found in the database.</td>
        </tr>
    }
</tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        const ctx = document.getElementById('predictionChart').getContext('2d');
        
        const data = {
            labels: ['Economic', 'Industrial', 'Business', 'General'],
            datasets: [{
                data: [
                    @ViewBag.EconomyCount, 
                    @ViewBag.IndustryCount, 
                    @ViewBag.BusinessCount, 
                    @ViewBag.GeneralCount
                ],
                backgroundColor: [
                    '#f43f5e', // Rose
                    '#3b82f6', // Blue
                    '#10b981', // Emerald
                    '#f59e0b'  // Amber
                ],
                hoverOffset: 20,
                borderWidth: 0,
                borderRadius: 10
            }]
        };

        new Chart(ctx, {
            type: 'doughnut',
            data: data,
            options: {
                cutout: '75%', 
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: 'white', font: { size: 12 }, padding: 20 }
                    }
                },
                maintainAspectRatio: false
            }
        });
    </script>
</body>
</html>